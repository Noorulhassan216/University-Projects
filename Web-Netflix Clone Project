Style Sheet (CSS file)
* {  margin: 0;  padding: 0;  box-sizing: border-box;  font-family: Arial, Helvetica, sans-serif;}

body {  background-color: #000;  color: #fff;}

/* ================= NAVBAR ================= */
.navbar {  position: absolute;  top: 0;  width: 100%;  padding: 20px 50px;  display: flex;  justify-content: space-between;  align-items: center;  z-index: 10;}
ol, ul {  margin: 20px 40px;}
ol {  list-style-type: decimal;}
ul {  list-style-type: disc;}
li {  margin: 8px 0;}
.logo {  width: 140px;}

.nav-links {  display: flex;  gap: 25px;}

.nav-links a {  color: white;  text-decoration: none;  font-size: 16px;}

.nav-links a:hover {  color: #e50914;}

.signin-btn {  background: #e50914;  border: none;  color: white;  padding: 8px 18px;  border-radius: 3px;  font-size: 16px;  cursor: pointer;}

.signin-btn:hover {  background: darkred;}

/* ================= HERO ================= */
.hero {  background-image: url("https://assets.nflxext.com/ffe/siteui/vlv3/63a9db14-6c1d-4a8d-a64f-d5d79c751131/7e55ce06-7892-427d-9ed6-73ab6090b3db/PK-en-20240219-popsignuptwoweeks-perspective_alpha_website_large.jpg");  height: 90vh;  background-size: cover;  background-position: center;
  position: relative;}
.overlay {  background: rgba(0,0,0,0.6);  position: absolute;  inset: 0;}

.hero-content {  position: absolute;  top: 45%;  left: 50%;  transform: translate(-50%, -50%);  text-align: center;  width: 70%;}

.hero-content h1 {  font-size: 48px;  font-weight: bold;}

.hero-content h3 {  margin-top: 20px;  font-size: 24px;}

.hero-content p {  margin-top: 20px;  font-size: 18px;}

/* EMAIL */
.email-box {  margin-top: 25px;  display: flex;  justify-content: center;}

.email-box input {  padding: 15px; width: 55%;  outline: none;  font-size: 16px;}

.get-started {  padding: 16px 25px;  background: #e50914;  border: none;  color: white;  font-size: 18px;  
cursor: pointer;}

.get-started:hover {  background: darkred;}

/* ================= SECTIONS (FLEX) ================= */
.section {  display: flex;  align-items: center;  justify-content: center;  padding: 60px 40px;  border-top: 8px solid #222;
  gap: 40px;}
.section.reverse {  flex-direction: row-reverse;}

.section img {  width: 45%;  transition: transform 0.3s;}

.section img:hover {  transform: scale(1.08);}

.section .text {  width: 45%;}

.section .text h1 {  font-size: 40px;  margin-bottom: 20px;}

.section .text p:hover {  color: #e50914;}

/* ================= GRID (PLANS PAGE) ================= */
.grid-box {  display: grid;  grid-template-columns: repeat(3, 1fr);  gap: 20px;  padding: 40px;}

.grid-box img {  width: 500px; length: 500px;}

.grid-box img:hover {  transform: scale(1.5);}

/* ================= TABLE ================= */
table {
  width: 80%;  margin: 40px auto;  border-collapse: collapse;}

th, td {  border: 1px solid #555;  padding: 15px;  text-align: center;}

th {  background: #e50914;}

/* ================= FORMS ================= */
form {  width: 400px;  margin: 40px auto;}

input, textarea {  width: 100%;  padding: 10px;  margin: 8px 0;  outline: none;}

button {  background: #e50914;  color: white;  border: none;  padding: 12px;  cursor: pointer;}

button:hover {  background: darkred;}

/* ================= HELP BOX ================= */
.help-box {  text-align: center;  padding: 80px;}

/* ================= FOOTER ================= */
.footer {  text-align: center;  padding: 40px;  border-top: 8px solid #222;  color: gray;}
.option {  display: flex;  align-items: center;  margin: 8px 0;}

.option label {  display: flex;  align-items: center;  gap: 10px;  cursor: pointer;}

.option input[type="radio"],
.option input[type="checkbox"] {
  transform: scale(1.2);
}
.Order-List {display: grid;align-items: center;}
