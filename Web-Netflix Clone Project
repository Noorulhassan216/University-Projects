<!DOCTYPE html>
<html>
<head>
  <title>Sign Up</title>
  <link rel="stylesheet" href="style.css">
  <script src="script.js"></script>
</head>
<body>

<h1>Create Account</h1>

<form method="post" onsubmit="submitForm()">

  <input type="text" placeholder="Name" required>

  <input type="email" placeholder="Email" required>

  <textarea placeholder="Why do you want Netflix?"></textarea>

<p>Choose Plan:</p>

<div class="option">
  <label>
    <input type="radio" name="plan"> Monthly
  </label>
</div>

<div class="option">
  <label>
    <input type="radio" name="plan"> Yearly
  </label>
</div>

<p>Devices:</p>

<div class="option">
  <label>
    <input type="checkbox"> Mobile
  </label>
</div>

<div class="option">
  <label>
    <input type="checkbox"> TV
  </label>
</div>

<div class="option">
  <label>
    <input type="checkbox"> Laptop
  </label>
</div>

  <br><br>
  <button type="submit">Submit</button>
</form>

</body>
</html>

