Task 12: Triggers

Insert Trigger:

DELIMITER $$
CREATE TRIGGER before_employee_insert
BEFORE INSERT ON employee
FOR EACH ROW
BEGIN
    SET NEW.salary = IF(NEW.salary < 30000, 30000, NEW.salary);
END$$
DELIMITER ;

Update Trigger:

DELIMITER $$
CREATE TRIGGER after_salary_update
AFTER UPDATE ON employee
FOR EACH ROW
BEGIN
INSERT INTO salary_log VALUES (OLD.emp_id, OLD.salary, NEW.salary, CURDATE(), 'Salary Updated');
END$$
DELIMITER ;

Delete Trigger:

DELIMITER $$
CREATE TRIGGER before_delete_emp
BEFORE DELETE ON employee
FOR EACH ROW
BEGIN
INSERT INTO salary_log VALUES (OLD.emp_id, OLD.salary, 0, CURDATE(), 'Employee Deleted');
END $$
DELIMITER ;

Task 13: Cursor

Implicit Cursor:

DELIMITER $$
CREATE PROCEDURE get_emp_details(IN id INT)
BEGIN
    DECLARE name_var VARCHAR(30);
    DECLARE sal_var INT;
    SELECT emp_name, salary INTO name_var, sal_var 
    FROM employee 
    WHERE emp_id = id;
    SELECT name_var AS 'Employee Name', sal_var AS 'Salary';
END$$
DELIMITER ;
Calling Cursor:
CALL get_emp_details(5);

Explicit Cursor:

Simple Cursor

DELIMITER $$
CREATE PROCEDURE fetch_single_employee()
BEGIN
    DECLARE e_name VARCHAR(30);
    DECLARE e_salary INT;
    DECLARE emp_cursor CURSOR FOR 
     SELECT emp_name, salary FROM employee;
    OPEN emp_cursor;
    FETCH emp_cursor INTO e_name, e_salary;
    SELECT e_name AS Name, e_salary AS Salary;
    CLOSE emp_cursor;
END$$
DELIMITER ;


Calling Cursor:

CALL fetch_single_employee();

Cursor with Loop:

DELIMITER $$
CREATE PROCEDURE list_employee_salaries()
BEGIN
    DECLARE done INT DEFAULT FALSE;
    DECLARE emp_name_var VARCHAR(30);
    DECLARE emp_sal_var INT;
    DECLARE emp_cursor CURSOR FOR 
    SELECT emp_name, salary FROM employee;
    DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = TRUE;
    OPEN emp_cursor;
    read_loop: LOOP
        FETCH emp_cursor INTO emp_name_var, emp_sal_var;
        IF done THEN
            LEAVE read_loop;
        END IF;
        SELECT CONCAT('Employee: ', emp_name_var, ' | Salary: ', emp_sal_var) AS Info;
    END LOOP;
    CLOSE emp_cursor;
END$$
DELIMITER ;

Calling Cursor:
CALL list_employee_salaries();


