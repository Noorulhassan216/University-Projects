Project Title: Design and Implementation of Factory Management System (FMS)

Objective:
The objective of this lab is to design and implement a Factory Management System using MySQL Workbench. This system manages warehouse operations including departments, employees, machines, maintenance, products, and suppliers using relational database concepts.

Software Required:
1.MySQL Workbench
2.Windows OS

Database Description:
The FMS database consists of 10 tables:
1.	Warehouse
2.	Department
3.	Employee
4.	Machine
5.	Maintenance
6.	Product
7.	Supplier
8.	Supplier_product
9.	Warehouse_product
10.	Salary_log

Each table contains 5 attributes, including Primary Keys and Foreign Keys to maintain referential integrity.

Task 1: Create Database

CREATE DATABASE FMS;
USE FMS;

Task 2: Create Tables

CREATE TABLE warehouse (
    warehouse_id INT PRIMARY KEY,
    warehouse_name VARCHAR(50),
    city VARCHAR(30),
    established_year INT,
    contact_no VARCHAR(15)
);

CREATE TABLE department (
    dept_id INT PRIMARY KEY,
    dept_name VARCHAR(30),
    warehouse_id INT,
    floor_no INT,
    budget INT,
    FOREIGN KEY (warehouse_id) REFERENCES warehouse(warehouse_id)
);	

CREATE TABLE employee (
    emp_id INT PRIMARY KEY,
    emp_name VARCHAR(30),
    salary INT,
    dept_id INT,
    manager_id INT,
    FOREIGN KEY (dept_id) REFERENCES department(dept_id)
);

CREATE TABLE machine (
    machine_id INT PRIMARY KEY,
    machine_name VARCHAR(30),
    warehouse_id INT,
    purchase_year INT,
    status VARCHAR(20),
    FOREIGN KEY (warehouse_id) REFERENCES warehouse(warehouse_id)
);

CREATE TABLE maintenance (
    maintenance_id INT PRIMARY KEY,
    machine_id INT,
    emp_id INT,
    cost INT,
    maintenance_date DATE,
    FOREIGN KEY (machine_id) REFERENCES machine(machine_id),
    FOREIGN KEY (emp_id) REFERENCES employee(emp_id)
);
CREATE TABLE product (
    product_id INT PRIMARY KEY,
    product_name VARCHAR(30),
    price INT,
    category VARCHAR(20),
    description VARCHAR(50)
);

CREATE TABLE supplier (
    supplier_id INT PRIMARY KEY,
    supplier_name VARCHAR(30),
    city VARCHAR(30),
    phone VARCHAR(15),
    rating INT
);

CREATE TABLE supplier_product (
    supplier_id INT,
    product_id INT,
    supply_capacity INT,
    last_delivery DATE,
    PRIMARY KEY (supplier_id, product_id),
    FOREIGN KEY (supplier_id) REFERENCES supplier(supplier_id),
    FOREIGN KEY (product_id) REFERENCES product(product_id)
);

CREATE TABLE warehouse_product (
    warehouse_id INT,
    product_id INT,
    quantity INT,
    price INT,
    last_stock_date DATE,
    PRIMARY KEY (warehouse_id, product_id),
    FOREIGN KEY (warehouse_id) REFERENCES warehouse(warehouse_id),
    FOREIGN KEY (product_id) REFERENCES product(product_id)
);

CREATE TABLE salary_log (
    emp_id INT,
    old_salary INT,
    new_salary INT,
    change_date DATE,
    reason VARCHAR(50)
);

