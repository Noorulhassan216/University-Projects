While Loop with CONCAT:

DELIMITER $$
CREATE PROCEDURE while_demo()
BEGIN
    DECLARE i INT DEFAULT 1;
    DECLARE result VARCHAR(100) DEFAULT '';
    WHILE i <= 3 DO
        SET result = CONCAT(result, i, ' ');
        SET i = i + 1;
    END WHILE;
    SELECT result;
END$$
DELIMITER ;

Calling Procedure:
	CALL while_demo();

Do While Loop:

DELIMITER $$
CREATE PROCEDURE do_while_demo()
BEGIN
    DECLARE i INT DEFAULT 1;
    REPEAT
        SET i = i + 1;
    UNTIL i > 5
    END REPEAT;
    SELECT i;
END$$
DELIMITER ;

